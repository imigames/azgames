---
import AdminLayout from '../../layouts/AdminLayout.astro';
import {
  adminCreatePromptTemplate,
  adminDeletePromptTemplate,
  adminGetPromptTemplateById,
  adminGetPromptTemplateByKey,
  adminListPromptTemplates,
} from '../../lib/prompt-templates';

export const prerender = false;

const limit = 40;
const targetTypes = ['game', 'category'];
const actions = [
  'generate_meta_description',
  'generate_article',
  'generate_description',
  'generate_seo_title',
];

let actionError = '';
let actionSuccess = '';

const getDuplicateTemplateKey = async (templateKey: string) => {
  const baseKey = `${templateKey}_copy`;
  const baseResult = await adminGetPromptTemplateByKey(baseKey, { includeInactive: true });

  if (!baseResult.template) {
    return baseKey;
  }

  for (let index = 2; index < 100; index += 1) {
    const candidateKey = `${baseKey}_${index}`;
    const candidateResult = await adminGetPromptTemplateByKey(candidateKey, { includeInactive: true });

    if (!candidateResult.template) {
      return candidateKey;
    }
  }

  return `${baseKey}_${Date.now().toString(36)}`;
};

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const intent = String(formData.get('intent') ?? '');
  const id = String(formData.get('id') ?? '');

  if (intent === 'deactivate' && id) {
    const result = await adminDeletePromptTemplate(id);

    if (result.success) {
      actionSuccess = 'Prompt template deactivated.';
    } else {
      actionError = result.error ?? 'Unable to deactivate prompt template.';
    }
  }

  if (intent === 'duplicate' && id) {
    const { template, error } = await adminGetPromptTemplateById(id);

    if (error || !template) {
      actionError = error ?? 'Prompt template not found.';
    } else {
      const copyKey = await getDuplicateTemplateKey(template.templateKey);
      const result = await adminCreatePromptTemplate({
        templateKey: copyKey,
        name: `${template.name} Copy`,
        description: template.description ?? '',
        targetType: template.targetType ?? '',
        action: template.action ?? '',
        variables: template.variables,
        systemPrompt: template.systemPrompt ?? '',
        userPrompt: template.userPrompt,
        isActive: false,
      });

      if (result.success) {
        actionSuccess = 'Prompt template duplicated as inactive copy.';
      } else {
        actionError = result.error ?? 'Unable to duplicate prompt template.';
      }
    }
  }
}

const search = Astro.url.searchParams.get('search')?.trim() ?? '';
const targetType = Astro.url.searchParams.get('target_type')?.trim() ?? '';
const action = Astro.url.searchParams.get('action')?.trim() ?? '';
const requestedPage = Number(Astro.url.searchParams.get('page') ?? '1');
const page = Number.isFinite(requestedPage) ? Math.max(1, Math.trunc(requestedPage)) : 1;
const { templates, total, hasNext, error } = await adminListPromptTemplates({
  search,
  targetType,
  action,
  page,
  limit,
});

const formatDate = (value: string | null) =>
  value
    ? new Intl.DateTimeFormat('en', {
        dateStyle: 'medium',
        timeStyle: 'short',
      }).format(new Date(value))
    : '-';

const buildPageHref = (pageNumber: number) => {
  const params = new URLSearchParams();

  if (search) params.set('search', search);
  if (targetType) params.set('target_type', targetType);
  if (action) params.set('action', action);
  if (pageNumber > 1) params.set('page', String(pageNumber));

  const query = params.toString();
  return query ? `/admin/prompt-templates?${query}` : '/admin/prompt-templates';
};
---

<AdminLayout
  title="Prompt Templates | Free Game Zone"
  description="Manage AI prompts used to generate SEO content for games and categories."
>
  <div slot="actions" class="admin-header-actions">
    <a class="admin-primary-btn" href="/admin/prompt-templates/new">Add Template</a>
  </div>

  <section class="admin-list-page" aria-labelledby="admin-prompt-templates-title">
    <div class="admin-list-heading">
      <div>
        <h1 id="admin-prompt-templates-title">Prompt Templates</h1>
        <p>{total} template{total === 1 ? '' : 's'} found</p>
      </div>
    </div>

    <form class="admin-filter-bar" method="get" action="/admin/prompt-templates">
      <label>
        <span>Search</span>
        <input type="search" name="search" value={search} placeholder="Name, key, or description" />
      </label>

      <label>
        <span>Target type</span>
        <select name="target_type">
          <option value="">All</option>
          {
            targetTypes.map((type) => (
              <option value={type} selected={type === targetType}>{type}</option>
            ))
          }
        </select>
      </label>

      <label>
        <span>Action</span>
        <select name="action">
          <option value="">All</option>
          {
            actions.map((item) => (
              <option value={item} selected={item === action}>{item}</option>
            ))
          }
        </select>
      </label>

      <button type="submit">Filter</button>
      {(search || targetType || action) && <a class="admin-link-btn" href="/admin/prompt-templates">Clear</a>}
    </form>

    {error && <p class="admin-error">{error}</p>}
    {actionError && <p class="admin-error">{actionError}</p>}
    {actionSuccess && <p class="admin-success">{actionSuccess}</p>}

    <div class="admin-table-wrap">
      <table class="admin-table admin-prompt-templates-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Template key</th>
            <th>Target</th>
            <th>Action</th>
            <th>Status</th>
            <th>Updated</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {
            templates.length > 0 ? (
              templates.map((template) => (
                <tr>
                  <td>{template.name}</td>
                  <td><code>{template.templateKey}</code></td>
                  <td>{template.targetType ?? '-'}</td>
                  <td class="admin-text-compact">{template.action ?? '-'}</td>
                  <td>
                    <span class:list={['admin-status-badge', template.isActive ? 'is-ok' : 'is-muted']}>
                      {template.isActive ? 'Active' : 'Inactive'}
                    </span>
                  </td>
                  <td>{formatDate(template.updatedAt ?? template.createdAt)}</td>
                  <td>
                    <div class="admin-table-actions">
                      <a href={`/admin/prompt-templates/${template.id}/edit`}>Edit</a>
                      <form method="post" action={Astro.url.pathname + Astro.url.search}>
                        <input type="hidden" name="intent" value="duplicate" />
                        <input type="hidden" name="id" value={template.id} />
                        <button type="submit">Duplicate</button>
                      </form>
                      <form method="post" action={Astro.url.pathname + Astro.url.search}>
                        <input type="hidden" name="intent" value="deactivate" />
                        <input type="hidden" name="id" value={template.id} />
                        <button type="submit" disabled={!template.isActive}>Deactivate</button>
                      </form>
                    </div>
                  </td>
                </tr>
              ))
            ) : (
              <tr>
                <td colspan="7">No prompt templates found.</td>
              </tr>
            )
          }
        </tbody>
      </table>
    </div>

    <nav class="pagination" aria-label="Prompt templates pagination">
      {
        page > 1 ? (
          <a class="pagination-link" href={buildPageHref(page - 1)}>Previous</a>
        ) : (
          <span class="pagination-link pagination-link--disabled" aria-disabled="true">Previous</span>
        )
      }
      <span class="pagination-current">Page {page}</span>
      {
        hasNext ? (
          <a class="pagination-link" href={buildPageHref(page + 1)}>Next</a>
        ) : (
          <span class="pagination-link pagination-link--disabled" aria-disabled="true">Next</span>
        )
      }
    </nav>
  </section>
</AdminLayout>
