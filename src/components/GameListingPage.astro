---
import GameCard from './GameCard.astro';
import type { Game } from '../types/game';

interface Props {
  title: string;
  games: Game[];
  page: number;
  hasNext: boolean;
  basePath: string;
}

const { title, games, page, hasNext, basePath } = Astro.props;
const getPageHref = (pageNumber: number) =>
  pageNumber <= 1 ? basePath : `${basePath}${basePath.includes('?') ? '&' : '?'}page=${pageNumber}`;
---

<div class="category-page">
  <header class="category-page-header">
    <h1>{title}</h1>
  </header>

  <section class="category-game-grid" aria-label={title}>
    {games.map((game) => <GameCard game={game} size="small" />)}
  </section>

  <nav class="pagination" aria-label={`${title} pagination`}>
    {
      page > 1 ? (
        <a class="pagination-link" href={getPageHref(page - 1)}>Previous</a>
      ) : (
        <span class="pagination-link pagination-link--disabled" aria-disabled="true">Previous</span>
      )
    }
    <span class="pagination-current">Page {page}</span>
    {
      hasNext ? (
        <a class="pagination-link" href={getPageHref(page + 1)}>Next</a>
      ) : (
        <span class="pagination-link pagination-link--disabled" aria-disabled="true">Next</span>
      )
    }
  </nav>
</div>
